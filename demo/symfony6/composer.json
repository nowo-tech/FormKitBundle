{
  "name": "nowo-tech/form-kit-demo-symfony6",
  "description": "Demo for Form Kit Bundle - Symfony 6",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1,<8.6",
    "a2lix/translation-form-bundle": "^4.0",
    "doctrine/collections": "^2.2",
    "nowo-tech/form-kit-bundle": "@dev",
    "symfony/console": "^6.4",
    "symfony/dotenv": "^6.4",
    "symfony/framework-bundle": "^6.4",
    "symfony/form": "^6.4",
    "symfony/http-kernel": "^6.4",
    "symfony/runtime": "^6.4",
    "symfony/stimulus-bundle": "^6.4",
    "symfony/twig-bundle": "^6.4",
    "symfony/ux-cropperjs": "^2.0",
    "symfony/ux-dropzone": "^2.0",
    "symfony/validator": "^6.4"
  },
  "require-dev": {
    "symfony/debug-bundle": "6.4.*",
    "symfony/web-profiler-bundle": "6.4.*"
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*"
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "@php bin/console cache:clear"
    },
    "post-install-cmd": ["@auto-scripts"],
    "post-update-cmd": ["@auto-scripts"]
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "6.4.*"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "/var/form-kit-bundle",
      "options": {
        "symlink": true
      }
    }
  ],
  "minimum-stability": "dev"
}
