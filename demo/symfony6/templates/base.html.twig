<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Form Kit Bundle Demo{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="{{ asset('build/assets/app.css') }}">
</head>
<body>
<nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
        <a class="navbar-brand demo-navbar-brand" href="{{ path('form_demo_index') }}">Form Kit Demo</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link" href="{{ path('form_demo_form_type') }}">FormType</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('form_demo_controller_form') }}">Controller Form</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('form_demo_search') }}">Search</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('form_demo_example_form') }}">Example</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('form_demo_dropzone') }}">Dropzone</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('form_demo_cropper') }}">Cropper</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('form_demo_translations') }}">Translations</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('form_demo_nested') }}">Nested</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('form_demo_multistep') }}">Multi-step</a></li>
            </ul>
        </div>
    </div>
</nav>

<main class="container py-4">
    {% block body %}{% endblock %}
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
<script type="module" src="{{ asset('build/assets/app.js') }}"></script>
</body>
</html>
