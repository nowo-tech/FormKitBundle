{% extends 'base.html.twig' %}

{% block title %}Search Form - Form Kit Demo{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Search Form</h1>
  <a class="btn btn-sm btn-outline-secondary" href="{{ path('form_demo_index') }}">Back</a>
</div>
<p class="text-secondary mb-4">Inline search bar using Form Kit conventions (<code>search_form.*</code>). Same form, different layout: single bar with filter and action.</p>

<div class="card search-bar-card shadow-sm">
  <div class="card-body p-4">
    {{ form_start(form) }}
    <label for="{{ form.q.vars.id }}" class="form-label small text-muted mb-2">Search</label>
    <div class="input-group input-group-lg">
      {{ form_widget(form.q, { attr: { class: 'form-control', 'aria-label': 'Search query' } }) }}
      <span class="input-group-text bg-light border-start-0 border-end-0 px-3">in</span>
      {{ form_widget(form.category, { attr: { class: 'form-select flex-grow-0', style: 'max-width: 11rem;', 'aria-label': 'Category' } }) }}
      <button type="submit" class="btn btn-primary px-4">Search</button>
    </div>
    <div class="d-flex flex-wrap gap-3 mt-2">
      {{ form_errors(form.q) }}
      {{ form_errors(form.category) }}
      {% if form.category.vars.help is defined and form.category.vars.help %}
        <small class="text-muted">{{ form.category.vars.help }}</small>
      {% endif %}
    </div>
    {% for child in form %}
      {% if child.vars.name == '_token' %}
        {{ form_row(child) }}
      {% endif %}
    {% endfor %}
    {{ form_end(form, { render_rest: false }) }}
  </div>
</div>

{% if submitted %}
  <div class="alert alert-info mt-4 mb-0 shadow-sm">
    <strong>Submitted:</strong> q = <code>{{ submitted.q }}</code>, category = <code>{{ submitted.category }}</code>
  </div>
{% endif %}
{% endblock %}
