{% extends 'base.html.twig' %}

{% block title %}Multi-step Form - Form Kit Demo{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Multi-step Form</h1>
  <a class="btn btn-sm btn-outline-secondary" href="{{ path('form_demo_index') }}">Back</a>
</div>
<p class="text-secondary mb-4">Wizard built from an array: contact → address → confirm. Same Form Kit conventions per step (<code>demo_wizard_contact.*</code>, <code>demo_wizard_address.*</code>).</p>

<div class="card form-card shadow-sm">
  <div class="card-body p-4">
    <ul class="nav nav-pills nav-fill mb-4">
      {% for key in wizard.stepKeys %}
        <li class="nav-item">
          <span class="nav-link {{ key == wizard.currentStepKey ? 'active' : '' }} {{ loop.index0 < wizard.currentIndex ? 'text-success' : '' }}">
            {{ loop.index }}. {{ wizard.getStepLabel(key) }}
          </span>
        </li>
      {% endfor %}
    </ul>

    {{ form_start(form) }}
    <div class="row g-3">
      {% for child in form %}
        <div class="col-12">{{ form_row(child) }}</div>
      {% endfor %}
    </div>
    <div class="form-kit-buttons">
      <button type="submit" class="btn btn-primary">{{ wizard.currentIndex + 1 >= wizard.stepKeys|length ? 'Finish' : 'Next' }}</button>
    </div>
    {{ form_end(form, { render_rest: false }) }}
  </div>
</div>
{% endblock %}
