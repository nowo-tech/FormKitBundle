{% extends 'base.html.twig' %}

{% block title %}Translations - Form Kit Demo{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Translations</h1>
  <a class="btn btn-sm btn-outline-secondary" href="{{ path('form_demo_index') }}">Back</a>
</div>
<p class="text-secondary mb-4">A2lix <code>TranslationsFormsType</code> with <code>form_type</code> = TranslationItemType and <code>data_class</code> in form_options. TranslationItemType uses <code>buildFormFromArray</code> for title and description.</p>

<div class="card form-card shadow-sm rounded-3">
  <div class="card-body p-4">
    {{ form_start(form) }}
    {% set translations_form = form.translations %}
    <ul class="nav nav-tabs border-0 border-bottom mb-0 px-0" id="translations-tab" role="tablist">
      {% for locale, localeForm in translations_form %}
        <li class="nav-item" role="presentation">
          <button class="nav-link rounded-0 border-0 py-3 px-3 {{ loop.first ? 'active' }}" id="tab-{{ locale }}" data-bs-toggle="tab" data-bs-target="#pane-{{ locale }}" type="button" role="tab" aria-controls="pane-{{ locale }}" aria-selected="{{ loop.first ? 'true' : 'false' }}">{{ localeForm.vars.label|default(locale) }}</button>
        </li>
      {% endfor %}
    </ul>
    <div class="tab-content pt-4" id="translations-tab-content">
      {% for locale, localeForm in translations_form %}
        <div class="tab-pane fade {{ loop.first ? 'show active' }}" id="pane-{{ locale }}" role="tabpanel" aria-labelledby="tab-{{ locale }}">
          <div class="mb-3">
            {{ form_row(localeForm.title) }}
          </div>
          <div class="mb-0">
            {{ form_row(localeForm.description) }}
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="form-kit-buttons mt-4 pt-3 border-top">
      <button type="submit" class="btn btn-primary rounded-2 px-4">Save</button>
    </div>
    {{ form_end(form, { render_rest: false }) }}
  </div>
</div>

{% if submitted %}
  <div class="alert alert-success mt-4 mb-0 shadow-sm rounded-3">
    <strong>Submitted:</strong>
    <pre class="mb-0 small">{% for locale, t in submitted.translations %}{{ locale }}: {{ t.title }} — {{ t.description }}{{ "\n" }}{% endfor %}</pre>
  </div>
{% endif %}
{% endblock %}
